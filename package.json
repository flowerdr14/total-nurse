{
  "name": "total-ganho-emr",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron-main.js",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "node -e \"const fs = require('fs'); ['dist', 'release'].forEach(p => fs.rmSync(p, {recursive: true, force: true}))\"",
    "lint": "tsc --noEmit",
    "electron:dev": "NODE_ENV=development wait-on http://localhost:3000 && electron .",
    "electron:build": "npm run build && electron-builder",
    "android:init": "cap init",
    "android:add": "cap add android",
    "android:sync": "npm run build && cap sync android",
    "android:open": "cap open android"
  },
  "build": {
    "appId": "com.total.ganho.emr",
    "productName": "TOTAL 간호",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron-main.js",
      "package.json",
      "total_nursing_icon.ico"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "icon": "total_nursing_icon.ico",
      "artifactName": "${productName}_${version}.${ext}"
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@google/genai": "^1.29.0",
    "@netlify/blobs": "^10.7.1",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.10.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.4"
  }
}
